---
import { TIMELINE } from "../data/config";
---

<section id="timeline" class="py-20 bg-surface">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-primary text-center">
      Timeline
    </h2>

    <div class="mt-16 hidden md:block">
      <div class="relative">
        <div class="absolute top-2 left-0 right-0 h-0.5 bg-primary/20" />

        <div class="grid grid-cols-4 gap-6 relative">
          {TIMELINE.map((item, i) => (
            <div class="flex flex-col items-center">
              <div class="w-4 h-4 rounded-full bg-primary border-4 border-surface relative z-10 shrink-0 dot-pop" style={`animation-delay: ${i * 0.15}s`} />
              <div class="w-0.5 h-6 bg-primary/20" />
              <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 w-full">
                <p class="text-primary font-bold text-sm">{item.date}</p>
                <p class="mt-1 text-sm text-gray-600">{item.label}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-12 md:hidden space-y-6">
      {TIMELINE.map((item, i) => (
        <div class="flex gap-4 items-start">
          <div class="flex flex-col items-center">
            <div class="w-3 h-3 rounded-full bg-primary shrink-0 mt-1.5 dot-pop" style={`animation-delay: ${i * 0.15}s`} />
            <div class="w-0.5 flex-1 bg-primary/20" />
          </div>
          <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 flex-1">
            <p class="text-primary font-bold text-sm">{item.date}</p>
            <p class="mt-1 text-sm text-gray-600">{item.label}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
