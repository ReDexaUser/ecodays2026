---
import { CONTACT } from "../data/config";
---

<section id="contact" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-primary text-center">
      Kontak
    </h2>
    <p class="mt-3 text-gray-600 text-center">
      Punya pertanyaan? Hubungi kami!
    </p>

    <div class="mt-12 max-w-lg mx-auto space-y-4">
      <div data-tilt class="flex items-center gap-4 bg-surface rounded-xl p-5 hover:-translate-y-1 transition-all">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm text-gray-500">Email</p>
          <p class="font-medium text-gray-800">{CONTACT.email}</p>
        </div>
      </div>

      <div data-tilt class="flex items-center gap-4 bg-surface rounded-xl p-5 hover:-translate-y-1 transition-all">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm text-gray-500">Instagram</p>
          <p class="font-medium text-gray-800">{CONTACT.instagram}</p>
        </div>
      </div>

      <div data-tilt class="flex items-center gap-4 bg-surface rounded-xl p-5 hover:-translate-y-1 transition-all">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm text-gray-500">WhatsApp</p>
          <p class="font-medium text-gray-800">{CONTACT.whatsapp}</p>
        </div>
      </div>
    </div>
  </div>
</section>
