---
import { NAV } from "../data/config";

const { current } = Astro.props;
const isSubpage = !!current;
const base = import.meta.env.BASE_URL;
---

<nav data-subpage={isSubpage ? "true" : "false"} class="fixed top-0 left-0 right-0 z-50 bg-bg/90 backdrop-blur-lg border-b border-white/5">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href={isSubpage ? base : "#"} class="text-xl font-bold text-primary tracking-tight hover:text-accent transition-colors">ECODAYS</a>

    <div class="hidden md:flex items-center gap-8">
      <ul class="flex gap-1">
        {NAV.map((item) => (
          <li>
            <a
              id={`nav-${item.href.replace("#", "")}`}
              href={isSubpage ? base + item.href : item.href}
              class="nav-link px-3 py-2 text-sm font-medium text-text/60 hover:text-primary transition-colors"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <button id="menu-toggle" class="md:hidden p-2 relative z-50" aria-label="Toggle menu">
      <div class="w-6 h-5 flex flex-col justify-between">
        <span class="block h-0.5 w-full bg-text/70 rounded transition-all duration-300 origin-center" id="bar-1"></span>
        <span class="block h-0.5 w-full bg-text/70 rounded transition-all duration-300" id="bar-2"></span>
        <span class="block h-0.5 w-full bg-text/70 rounded transition-all duration-300 origin-center" id="bar-3"></span>
      </div>
    </button>
  </div>

  <div id="mobile-menu" class="md:hidden bg-bg/95 backdrop-blur-lg border-t border-white/5 overflow-hidden transition-all duration-300" style="max-height: 0; opacity: 0;">
    <ul class="flex flex-col gap-1 px-4 py-2">
      {NAV.map((item, i) => (
        <li>
          <a
            id={`nav-${item.href.replace("#", "")}`}
            href={isSubpage ? base + item.href : item.href}
            class="nav-link block py-3 px-3 text-sm font-medium text-text/60 hover:text-primary transition-colors rounded-lg hover:bg-white/5"
            style={`transition-delay: ${i * 50}ms`}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const bars = ["bar-1", "bar-2", "bar-3"].map((id) => document.getElementById(id));

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isOpen = menu.style.maxHeight !== "0px" && menu.style.maxHeight !== "";
      if (isOpen) {
        menu.style.maxHeight = "0";
        menu.style.opacity = "0";
        bars[0] && (bars[0].style.transform = "");
        bars[1] && (bars[1].style.opacity = "");
        bars[2] && (bars[2].style.transform = "");
      } else {
        menu.style.maxHeight = menu.scrollHeight + "px";
        menu.style.opacity = "1";
        bars[0] && (bars[0].style.transform = "rotate(45deg) translateY(7px)");
        bars[1] && (bars[1].style.opacity = "0");
        bars[2] && (bars[2].style.transform = "rotate(-45deg) translateY(-7px)");
      }
    });
  }

  const isSubpage = document.querySelector("nav")?.dataset.subpage === "true";
  if (!isSubpage) {
    const links = document.querySelectorAll('[id^="nav-"]');
    const sections = document.querySelectorAll("section[id]");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            links.forEach((l) => {
              l.classList.remove("active", "text-primary", "font-semibold");
              l.classList.add("text-text/60");
              if (l.id === "nav-" + entry.target.id) {
                l.classList.remove("text-text/60");
                l.classList.add("active", "text-primary", "font-semibold");
              }
            });
          }
        });
      },
      { threshold: 0.3 }
    );

    sections.forEach((s) => observer.observe(s));
  }
</script>
