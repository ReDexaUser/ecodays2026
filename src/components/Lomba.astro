---
import { LOMBA, HERO } from "../data/config";
---

<section id="lomba" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-primary text-center">
      Lomba
    </h2>
    <p class="mt-3 text-gray-600 text-center">
      Ikuti kompetisi dan tunjukkan inovasimu!
    </p>

    <div class="mt-12 grid md:grid-cols-2 gap-8">
      {LOMBA.map((lomba, i) => (
        <div data-tilt class="bg-surface rounded-2xl overflow-hidden border border-gray-100 hover:-translate-y-1 hover:shadow-lg transition-[translate,box-shadow]">
          <div class="h-48 bg-primary/10 flex items-center justify-center text-primary/30 text-sm">
            Poster {lomba.name}
          </div>
          <div class="p-6">
            <span class="text-xs font-semibold text-accent uppercase tracking-wider">
              {lomba.tagline}
            </span>
            <h3 class="mt-2 text-xl font-bold text-primary">{lomba.name}</h3>
            <p class="mt-2 text-gray-600 text-sm">{lomba.description}</p>
            <a
              href={HERO.ctaLink}
              class="mt-4 inline-block text-sm font-semibold text-primary hover:text-primary-light transition-colors"
            >
              Daftar &rarr;
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
