---
import { CONTACT, FOOTER } from "../data/config";

const waLink = `https://wa.me/${CONTACT.whatsapp.replace(/[^0-9]/g, "")}`;
const igLink = `https://instagram.com/${CONTACT.instagram.replace("@", "")}`;
---

<footer id="contact" class="bg-primary text-white py-6">
  <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4">
    <p class="text-sm text-white/50">{FOOTER.copyright}</p>
    <div class="flex items-center gap-3 text-sm">
      <a href={`mailto:${CONTACT.email}`} class="text-white/50 hover:text-white transition-colors">
        Email
      </a>
      <span class="text-white/20">|</span>
      <a href={igLink} class="text-white/50 hover:text-white transition-colors">
        Instagram
      </a>
      <span class="text-white/20">|</span>
      <a href={waLink} class="text-white/50 hover:text-white transition-colors">
        WhatsApp
      </a>
    </div>
  </div>
</footer>
