---
import { CONTACT, FOOTER } from "../data/config";

const waLink = `https://wa.me/${CONTACT.whatsapp.replace(/[^0-9]/g, "")}`;
const igLink = `https://instagram.com/${CONTACT.instagram.replace("@", "")}`;
---

<div class="bg-surface">
  <div class="max-w-6xl mx-auto px-4">
    <hr class="border-white/10" />
  </div>
</div>
<footer class="bg-[#0B3618] text-white py-8">
  <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4">
    <p class="text-sm text-white/40">{FOOTER.copyright}</p>
    <div class="flex items-center gap-2 text-sm">
      <a href={`mailto:${CONTACT.email}`} class="px-3 py-1.5 text-white/50 hover:text-white hover:bg-white/5 rounded-lg transition-all">
        Email
      </a>
      <span class="text-white/10">|</span>
      <a href={igLink} class="px-3 py-1.5 text-white/50 hover:text-white hover:bg-white/5 rounded-lg transition-all">
        Instagram
      </a>
      <span class="text-white/10">|</span>
      <a href={waLink} class="px-3 py-1.5 text-white/50 hover:text-white hover:bg-white/5 rounded-lg transition-all">
        WhatsApp
      </a>
    </div>
  </div>
</footer>