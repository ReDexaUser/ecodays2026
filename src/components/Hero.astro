---
import { HERO, SPONSORS } from "../data/config";
import titleImage from "../assets/title.png";
import xlUrls from "../assets/sponsors/xl/urls.json";
import lUrls from "../assets/sponsors/l/urls.json";
import mUrls from "../assets/sponsors/m/urls.json";

const xlImages = import.meta.glob('/src/assets/sponsors/xl/*.{png,jpg,jpeg,svg}', { eager: true, query: '?url', import: 'default' });
const lImages = import.meta.glob('/src/assets/sponsors/l/*.{png,jpg,jpeg,svg}', { eager: true, query: '?url', import: 'default' });
const mImages = import.meta.glob('/src/assets/sponsors/m/*.{png,jpg,jpeg,svg}', { eager: true, query: '?url', import: 'default' });
const heroImages = import.meta.glob('/src/assets/hero/*.{jpg,jpeg,png,JPG,JPEG,PNG,webp,WEBP}', { eager: true, query: '?url', import: 'default' });

interface SponsorItem {
    name: string;
    url: string;
    src: string;
}

function resolveTier(images: Record<string, string>, urls: Record<string, string>): SponsorItem[] {
    return Object.entries(images).map(([path, src]) => {
        const filename = path.split('/').pop() || '';
        const name = filename.replace(/\.(png|jpg|jpeg|svg)$/i, '');
        const url = urls[filename] || '#';
        return { name, url, src };
    });
}

const xlSponsors = resolveTier(xlImages as Record<string, string>, xlUrls as Record<string, string>);
const lSponsors = resolveTier(lImages as Record<string, string>, lUrls as Record<string, string>);
const mSponsors = resolveTier(mImages as Record<string, string>, mUrls as Record<string, string>);
const heroSlides = Object.values(heroImages as Record<string, string>);
---

<section class="min-h-screen flex items-center justify-center pt-16 bg-bg relative overflow-hidden">
  <!-- Slideshow -->
  <div class="absolute inset-0">
    {heroSlides.map((src, i) => (
      <div
        class="absolute inset-0 bg-cover bg-center transition-opacity duration-1000"
        style={`background-image: url(${src}); opacity: ${i === 0 ? 1 : 0}`}
        data-slide={i}
      />
    ))}
  </div>

  <!-- Layer 1: Warm gold glow from bottom-right (sunset feel) -->
  <div class="absolute bottom-0 right-0 w-1/2 h-1/2 opacity-70" style="background: radial-gradient(ellipse at bottom right, rgba(246, 166, 35, 0.12), transparent 60%)"></div>

  <!-- Layer 2: Bottom fade — darkens gradually toward footer for sponsor legibility -->
  <div class="absolute inset-x-0 bottom-0 h-2/3" style="background: linear-gradient(to top, #0D4720 0%, rgba(13, 71, 32, 0.55) 35%, transparent 100%)"></div>

  <!-- Layer 3: Radial vignette — soft darkening at edges, clear center for photo -->
  <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 35%, transparent 30%, rgba(13, 71, 32, 0.4) 100%)"></div>

  <!-- Floating orbs -->
  <div class="absolute top-20 left-10 w-80 h-80 bg-white/[0.06] rounded-full blur-3xl float parallax" data-parallax-speed="0.4"></div>
  <div class="absolute bottom-32 right-10 w-96 h-96 bg-accent/[0.06] rounded-full blur-3xl float-slow parallax" data-parallax-speed="0.25"></div>
  <div class="absolute top-1/3 right-1/4 w-64 h-64 bg-white/[0.04] rounded-full blur-3xl pulse-glow"></div>

  <!-- Content -->
  <div class="max-w-6xl mx-auto px-4 py-20 flex flex-col items-center text-center relative z-10">
    <img
      src={titleImage.src}
      alt="ECODAYS"
      class="max-w-full h-auto fade-in-up"
      style="max-height: 200px; width: auto; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5)) drop-shadow(0 0 15px rgba(0,0,0,0.25)) drop-shadow(0 0 40px rgba(0,0,0,0.1))"
    />

    <div class="mt-20 w-full fade-in-up" style="transition-delay: 150ms">
      <div class="bg-white/[0.4] border border-white/[0.5] rounded-2xl p-6 md:p-8">
        <p class="text-xs text-text-dark/80 font-bold uppercase tracking-[0.2em] mb-6 text-center">{SPONSORS.title}</p>
        <div class="grid grid-cols-1 md:grid-cols-[6fr_3fr_2fr] gap-4 md:gap-6 items-start">
          <div class="flex flex-col gap-3">
            {xlSponsors.map((s) => (
              <a href={s.url} class="flex items-center justify-center p-4 h-28">
                <img src={s.src} alt={s.name} class="max-h-full object-contain" />
              </a>
            ))}
          </div>
          <div class="flex flex-col gap-3">
            {lSponsors.map((s) => (
              <a href={s.url} class="flex items-center justify-center p-3 h-16">
                <img src={s.src} alt={s.name} class="max-h-full object-contain" />
              </a>
            ))}
          </div>
          <div class="flex flex-col gap-3">
            {mSponsors.map((s) => (
              <a href={s.url} class="flex items-center justify-center p-2 h-12">
                <img src={s.src} alt={s.name} class="max-h-full object-contain" />
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll<HTMLElement>("[data-slide]");
  let current = 0;

  setInterval(() => {
    const next = (current + 1) % slides.length;
    slides.forEach((s, i) => {
      s.style.opacity = i === next ? "1" : "0";
    });
    current = next;
  }, 5000);
</script>
