---
import { HERO } from "../data/config";
import titleImage from "../assets/title.webp";

const heroImages = import.meta.glob('/src/assets/hero/*.{jpg,jpeg,png,JPG,JPEG,PNG,webp,WEBP}', { eager: true, query: '?url', import: 'default' });

const heroSlides = Object.values(heroImages as Record<string, string>);
---

<section class="min-h-screen flex items-center justify-center pt-16 bg-bg relative overflow-hidden">
  <!-- Slideshow -->
  <div class="absolute inset-0">
    {heroSlides.map((src, i) => (
      <div
        class="absolute inset-0 bg-cover bg-center transition-opacity duration-1000"
        style={`background-image: url(${src}); opacity: ${i === 0 ? 1 : 0}`}
        data-slide={i}
      />
    ))}
  </div>

  <!-- Layer 1: Warm gold glow from bottom-right (sunset feel) -->
  <div class="absolute bottom-0 right-0 w-1/2 h-1/2 opacity-70" style="background: radial-gradient(ellipse at bottom right, rgba(246, 166, 35, 0.12), transparent 60%)"></div>

  <!-- Layer 2: Bottom fade — darkens gradually toward footer for sponsor legibility -->
  <div class="absolute inset-x-0 bottom-0 h-2/3" style="background: linear-gradient(to top, #0D4720 0%, rgba(13, 71, 32, 0.55) 35%, transparent 100%)"></div>

  <!-- Layer 3: Radial vignette — soft darkening at edges, clear center for photo -->
  <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 35%, transparent 30%, rgba(13, 71, 32, 0.4) 100%)"></div>

  <!-- Floating orbs -->
  <div class="absolute top-20 left-10 w-80 h-80 bg-white/[0.06] rounded-full blur-3xl float parallax" data-parallax-speed="0.4"></div>
  <div class="absolute bottom-32 right-10 w-96 h-96 bg-accent/[0.06] rounded-full blur-3xl float-slow parallax" data-parallax-speed="0.25"></div>
  <div class="absolute top-1/3 right-1/4 w-64 h-64 bg-white/[0.04] rounded-full blur-3xl pulse-glow"></div>

  <!-- Content -->
  <div class="max-w-6xl mx-auto px-4 py-20 flex flex-col items-center text-center relative z-10">
    <img
      src={titleImage.src}
      alt="ECODAYS"
      class="max-w-full h-auto fade-in-up"
      style="max-height: 200px; width: auto; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5)) drop-shadow(0 0 15px rgba(0,0,0,0.25)) drop-shadow(0 0 40px rgba(0,0,0,0.1))"
    />
  </div>
</section>

<script>
  const slides = document.querySelectorAll<HTMLElement>("[data-slide]");
  let current = 0;

  setInterval(() => {
    const next = (current + 1) % slides.length;
    slides.forEach((s, i) => {
      s.style.opacity = i === next ? "1" : "0";
    });
    current = next;
  }, 5000);
</script>