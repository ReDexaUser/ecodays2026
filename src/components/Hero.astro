---
import { HERO, SPONSORS } from "../data/config";
import xlUrls from "../assets/sponsors/xl/urls.json";
import lUrls from "../assets/sponsors/l/urls.json";
import mUrls from "../assets/sponsors/m/urls.json";

const xlImages = import.meta.glob('/src/assets/sponsors/xl/*.{png,jpg,jpeg,svg}', { eager: true, query: '?url', import: 'default' });
const lImages = import.meta.glob('/src/assets/sponsors/l/*.{png,jpg,jpeg,svg}', { eager: true, query: '?url', import: 'default' });
const mImages = import.meta.glob('/src/assets/sponsors/m/*.{png,jpg,jpeg,svg}', { eager: true, query: '?url', import: 'default' });

interface SponsorItem {
    name: string;
    url: string;
    src: string;
}

function resolveTier(images: Record<string, string>, urls: Record<string, string>): SponsorItem[] {
    return Object.entries(images).map(([path, src]) => {
        const filename = path.split('/').pop() || '';
        const name = filename.replace(/\.(png|jpg|jpeg|svg)$/i, '');
        const url = urls[filename] || '#';
        return { name, url, src };
    });
}

const xlSponsors = resolveTier(xlImages as Record<string, string>, xlUrls as Record<string, string>);
const lSponsors = resolveTier(lImages as Record<string, string>, lUrls as Record<string, string>);
const mSponsors = resolveTier(mImages as Record<string, string>, mUrls as Record<string, string>);
---

<section class="min-h-screen flex items-center justify-center pt-16 bg-gradient-to-b from-surface to-white relative overflow-hidden">
  <div class="absolute top-20 left-10 w-72 h-72 bg-primary/5 rounded-full blur-3xl parallax" data-parallax-speed="0.5"></div>
  <div class="absolute bottom-20 right-10 w-96 h-96 bg-accent/5 rounded-full blur-3xl parallax" data-parallax-speed="0.3"></div>
  <div class="max-w-6xl mx-auto px-4 py-20 flex flex-col items-center text-center relative z-10">
    <h1 class="text-6xl md:text-8xl lg:text-9xl font-black text-primary leading-none tracking-tight">
      {HERO.title.split('').map((char, i) => (
        <span class="reveal-char" style={`animation-delay: ${i * 100}ms`}>{char}</span>
      ))}
    </h1>

    <p class="mt-6 text-base text-gray-500 uppercase tracking-[0.3em]">
      Festival Lingkungan Tahunan
    </p>

    <a
      href={HERO.ctaLink}
      class="mt-10 inline-flex items-center gap-2 bg-accent text-white font-semibold px-8 py-3.5 rounded-lg text-lg hover:opacity-90 hover:scale-105 transition-all"
    >
      {HERO.cta}
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
      </svg>
    </a>

    <div class="mt-20 w-full">
      <p class="text-xs text-gray-400 uppercase tracking-widest mb-6">{SPONSORS.title}</p>
      <div class="grid grid-cols-1 md:grid-cols-[6fr_3fr_2fr] gap-6 md:gap-8 items-start">
        <div class="flex flex-col gap-4">
          {xlSponsors.map((s) => (
            <a href={s.url} class="h-28 block hover:scale-105 transition-transform">
              <img src={s.src} alt={s.name} class="w-full h-full object-contain" />
            </a>
          ))}
        </div>
        <div class="flex flex-col gap-4">
          {lSponsors.map((s) => (
            <a href={s.url} class="h-14 block hover:scale-105 transition-transform">
              <img src={s.src} alt={s.name} class="w-full h-full object-contain" />
            </a>
          ))}
        </div>
        <div class="flex flex-col gap-4">
          {mSponsors.map((s) => (
            <a href={s.url} class="h-9 block hover:scale-105 transition-transform">
              <img src={s.src} alt={s.name} class="w-full h-full object-contain" />
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
