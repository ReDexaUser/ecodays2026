---
import { SEMINAR } from "../data/config";

const base = import.meta.env.BASE_URL;
---

<section id="seminar" class="py-20 bg-surface relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-primary text-center fade-in-up">
      {SEMINAR.title}
    </h2>

    <div
      data-tilt="1"
      data-card-link={base + '/seminar'}
      class="mt-12 glass rounded-2xl overflow-hidden hover:-translate-y-1 transition-all duration-300 fade-in-up cursor-pointer group"
      style="transition-delay: 100ms"
    >
      <div class="relative h-56 flex items-center justify-center overflow-hidden" style="background: linear-gradient(135deg, #0d4720 0%, #1a6b30 50%, #2a7a35 100%)">
        <svg class="w-16 h-16 text-white/10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
        </svg>
      </div>
      <div class="p-6 md:p-8">
        <h3 class="text-xl font-bold text-primary">{SEMINAR.theme}</h3>
        <div class="mt-4 flex flex-wrap gap-4 text-sm text-text/60">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            {SEMINAR.date}
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            {SEMINAR.time}
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            {SEMINAR.venue}
          </span>
        </div>
        <p class="mt-4 text-text/60 leading-relaxed">{SEMINAR.description}</p>
        <div class="mt-6">
          <a
            href={base + '/seminar'}
            data-card-action
            class="inline-flex items-center gap-2 bg-accent text-white font-semibold px-7 py-3 rounded-xl hover:bg-accent/80 transition-all duration-200 hover:shadow-lg hover:shadow-accent/20 group/cta"
          >
            Daftar Seminar
            <span class="inline-block transition-transform duration-200 group-hover/cta:translate-x-1">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </div>
  <div class="absolute bottom-0 left-0 right-0 overflow-hidden leading-0 pointer-events-none" style="transform: translateY(1px)">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full h-10 md:h-14">
      <path d="M0,28 C240,56 480,0 720,28 C960,56 1200,0 1440,28 L1440,60 L0,60 Z" fill="#0D4720"/>
    </svg>
  </div>
</section>

<script>
  document.querySelectorAll("[data-card-link]").forEach((card) => {
    card.addEventListener("click", (e) => {
      if (e.target.closest("[data-card-action]")) return;
      const href = card.getAttribute("data-card-link");
      if (href && href !== "#") window.location.href = href;
    });
  });
</script>