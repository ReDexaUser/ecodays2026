---
import { SEMINAR, HERO } from "../data/config";
---

<section id="seminar" class="py-20 bg-surface">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-primary text-center">
      {SEMINAR.title}
    </h2>

    <div data-tilt="1" class="mt-12 bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:-translate-y-1 hover:shadow-lg transition-all">
      <div class="h-56 bg-primary/10 flex items-center justify-center text-primary/30 text-sm">
        Poster Seminar
      </div>
      <div class="p-6 md:p-8">
        <h3 class="text-xl font-bold text-primary">{SEMINAR.theme}</h3>
        <div class="mt-4 flex flex-wrap gap-4 text-sm text-gray-600">
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            {SEMINAR.date}
          </span>
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            {SEMINAR.time}
          </span>
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            {SEMINAR.venue}
          </span>
        </div>
        <p class="mt-4 text-gray-600">{SEMINAR.description}</p>
        <a
          href={HERO.ctaLink}
          class="mt-6 inline-block bg-primary text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary-light transition-colors"
        >
          Daftar Seminar
        </a>
      </div>
    </div>
  </div>
</section>
