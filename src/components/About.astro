---
import { ABOUT } from "../data/config";

const daicoImages = import.meta.glob<string>("/src/assets/daico/*.{png,PNG,jpg,jpeg,webp,WEBP}", { eager: true, query: "?url", import: "default" });
const daicoSit = daicoImages["/src/assets/daico/duduk-lihat-ke-kanan.webp"];
---

<section id="about" class="py-20 bg-bg relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-primary text-center fade-in-up">
      {ABOUT.title}
    </h2>

    <div class="mt-12 max-w-3xl mx-auto">
      <div
        data-tilt
        class="glass rounded-2xl p-12 md:p-16 text-center hover:-translate-y-1 transition-all duration-300 fade-in-up"
        style="transition-delay: 100ms"
      >
        <p class="text-text/80 leading-relaxed text-base md:text-lg text-justify"><Fragment set:html={ABOUT.description} /></p>
      </div>
    </div>
  </div>

  {daicoSit && (
    <img src={daicoSit} alt="" class="absolute bottom-0 left-0 w-48 md:w-64 opacity-10 md:opacity-30 pointer-events-none select-none" draggable="false" />
  )}

  <div class="absolute bottom-0 left-0 right-0 overflow-hidden leading-0 pointer-events-none" style="transform: translateY(1px)">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full h-10 md:h-14">
      <path d="M0,28 C240,56 480,0 720,28 C960,56 1200,0 1440,28 L1440,60 L0,60 Z" fill="#114F25"/>
    </svg>
  </div>
</section>