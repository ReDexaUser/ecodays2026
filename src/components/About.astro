---
import { ABOUT } from "../data/config";
---

<section id="about" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-primary text-center">
      {ABOUT.title}
    </h2>

    <p class="mt-6 text-lg text-gray-600 text-center max-w-3xl mx-auto">
      {ABOUT.vision}
    </p>

    <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {ABOUT.mission.map((item, i) => (
        <div data-tilt class="bg-surface rounded-xl p-6 hover:-translate-y-1 transition-[translate]">
          <span class="text-primary font-bold text-lg">0{i + 1}</span>
          <p class="mt-3 text-gray-700">{item}</p>
        </div>
      ))}
    </div>
  </div>
</section>
