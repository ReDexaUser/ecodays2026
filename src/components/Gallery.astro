<section id="dokumentasi" class="py-20 bg-surface">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-primary text-center">
      Dokumentasi
    </h2>
    <p class="mt-3 text-gray-600 text-center">
      Momen-momen seru ECODAYS sebelumnya
    </p>

    <div class="mt-12 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {Array.from({ length: 8 }).map((_, i) => (
        <div class="aspect-square bg-primary/5 rounded-xl flex items-center justify-center text-primary/20 text-sm" style={`transition-delay: ${i * 80}ms`}>
          Foto
        </div>
      ))}
    </div>
  </div>
</section>
