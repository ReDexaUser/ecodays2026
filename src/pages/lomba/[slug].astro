---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { LOMBA } from "../../data/config";

export async function getStaticPaths() {
  return LOMBA.map((l) => ({
    params: { slug: l.id },
  }));
}

const { slug } = Astro.params;
const lomba = LOMBA.find((l) => l.id === slug);

const posterImages = import.meta.glob<string>("/src/assets/poster/*.{jpeg,jpg,png,webp,WEBP}", { eager: true, query: "?url", import: "default" });
const imgSrc = posterImages[`/src/assets/poster/${lomba.poster}`];
const base = import.meta.env.BASE_URL;
const basePath = base === '/' ? '' : base.replace(/\/+$/, '');

const daicoImages = import.meta.glob<string>("/src/assets/daico/*.{jpeg,jpg,png,PNG,webp,WEBP}", { eager: true, query: "?url", import: "default" });
const daicoWave = daicoImages["/src/assets/daico/melambai.webp"];
const daicoSit = daicoImages["/src/assets/daico/duduk-lihat-ke-kanan.webp"];
const daicoLean = daicoImages["/src/assets/daico/bersandar-ke-depan.webp"];
---

<BaseLayout title={`${lomba.name} - ECODAYS`}>
  <Navbar current="lomba" />

  <!-- HERO: poster + title -->
  <section class="py-20 md:py-28 bg-bg relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 80% 20%, rgba(245,166,35,0.08) 0%, transparent 60%)"></div>
    <div class="absolute top-20 left-10 w-72 h-72 bg-white/[0.04] rounded-full blur-3xl float parallax" data-parallax-speed="0.3"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-accent/[0.05] rounded-full blur-3xl float-slow parallax" data-parallax-speed="0.2"></div>
    <div class="absolute top-1/3 right-1/4 w-64 h-64 bg-white/[0.03] rounded-full blur-3xl pulse-glow"></div>
    {daicoWave && (
      <img src={daicoWave} alt="" class="absolute bottom-4 right-4 w-40 md:w-52 opacity-10 md:opacity-30 pointer-events-none float-slow select-none" draggable="false" />
    )}

    <div class="max-w-6xl mx-auto px-4 relative z-10">
      <a
        href={base}
        class="inline-flex items-center gap-1.5 text-sm text-text/50 hover:text-accent transition-colors mb-8 group fade-in-up"
      >
        <svg class="w-4 h-4 transition-transform duration-200 group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Kembali ke Beranda
      </a>

      <div class="md:flex items-start gap-10 lg:gap-14">
        <!-- poster -->
        <div class="md:w-[44%] shrink-0 fade-in-up" style="transition-delay:80ms">
          {imgSrc ? (
            <div class="relative group cursor-pointer" id="poster-trigger">
              <div class="rounded-2xl overflow-hidden shadow-2xl shadow-black/40 ring-1 ring-white/10 transition-all duration-500 group-hover:shadow-accent/20 group-hover:ring-accent/20">
                <img
                  src={imgSrc}
                  alt={`Poster ${lomba.name}`}
                  id="poster-img"
                  class="w-full h-auto object-contain transition-transform duration-500 group-hover:scale-[1.03]"
                  loading="lazy"
                />
              </div>
              <div class="absolute bottom-3 right-3 bg-white/10 backdrop-blur-md text-white text-xs px-3 py-1.5 rounded-full border border-white/20 opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/></svg>
                Perbesar
              </div>
            </div>
          ) : (
            <div class="w-full aspect-[3/4] rounded-2xl glass flex items-center justify-center text-text/30 text-sm">
              Poster belum tersedia
            </div>
          )}
        </div>

        <!-- info -->
        <div class="md:w-[56%] mt-8 md:mt-0 fade-in-up" style="transition-delay:180ms">
          <span class="text-accent text-xs font-bold uppercase tracking-[0.2em]">{lomba.fullName}</span>
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-primary mt-2 leading-[0.95] tracking-tight">{lomba.name}</h1>
          <p class="mt-5 text-text/70 leading-relaxed text-base md:text-lg">{lomba.description}</p>

          <div class="mt-8 pt-6 border-t border-white/10">
            <p class="text-xs text-text/40 uppercase tracking-[0.2em] font-bold mb-2">Tema Kompetisi</p>
            <p class="text-lg md:text-xl text-primary font-semibold leading-relaxed">{lomba.theme}</p>
          </div>

          <div class="mt-8 flex flex-col gap-3">
            <a
              href={`https://${lomba.links.registration}`}
              target="_blank" rel="noopener"
              class="bg-accent text-white font-semibold px-6 py-3.5 rounded-xl text-center hover:bg-accent/90 hover:shadow-lg hover:shadow-accent/25 transition-all duration-300 hover:-translate-y-0.5 flex items-center justify-center gap-2"
            >
              Daftar Sekarang
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a
              href={`https://${lomba.links.guideBook}`}
              target="_blank" rel="noopener"
              class="border-2 border-accent/40 text-accent font-semibold px-6 py-3.5 rounded-xl text-center hover:bg-accent/10 hover:border-accent/60 transition-all duration-300 flex items-center justify-center gap-2"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
              Guide Book
            </a>
            <a
              href={`https://${lomba.links.moreInfo.replace(/^https?:\/\//, '')}`}
              target="_blank" rel="noopener"
              class="border-2 border-white/20 text-primary/80 font-semibold px-6 py-3.5 rounded-xl text-center hover:bg-mint/10 hover:border-mint/40 hover:text-mint transition-all duration-300 flex items-center justify-center gap-2"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-3.467a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
              Info Lengkap
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 overflow-hidden leading-[0] pointer-events-none" style="transform:translateY(1px)">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full h-10 md:h-14">
        <path d="M0,28 C240,56 480,0 720,28 C960,56 1200,0 1440,28 L1440,60 L0,60 Z" fill="#114F25"/>
      </svg>
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="py-20 bg-surface relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-4">
      <p class="text-xs text-text/40 uppercase tracking-[0.2em] font-bold mb-10 fade-in-up">Timeline</p>

      <div class="md:hidden space-y-4">
        {lomba.timeline.map((t, i) => (
          <div class="relative pl-8 fade-in-up" style={`transition-delay:${i * 80}ms`}>
            {i < lomba.timeline.length - 1 && (
              <div class="absolute left-[13px] top-8 bottom-0 border-l-[3px] border-dashed border-accent/30 -mb-4"></div>
            )}
            <div class="absolute left-0 top-1.5 w-7 h-7 rounded-full bg-accent text-white flex items-center justify-center text-xs font-bold shadow-lg shadow-accent/30 ring-2 ring-accent/20">{i + 1}</div>
            <div class="glass rounded-xl px-5 py-4 border-l-2 border-accent card-shadow">
              <p class="text-sm text-accent font-semibold">{t.date}</p>
              <p class="text-primary font-medium mt-1">{t.label}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="hidden md:block fade-in-up" style="transition-delay:100ms">
        <div style={`display:grid;grid-template-columns:repeat(${lomba.timeline.length},1fr);grid-template-rows:1fr auto 1fr`}>
          <div class="self-center h-[3px] bg-accent/20 z-0" style="grid-column:1/-1;grid-row:2"></div>

          {lomba.timeline.map((t, i) => (
            <>
              <div class="flex items-end justify-center pb-2 z-[1]" style={`grid-column:${i + 1};grid-row:1`}>
                {i % 2 !== 0 && (
                  <div class="glass rounded-xl px-3 py-3 text-center border-b-2 border-accent w-[85%] break-words fade-in-up card-shadow" style={`transition-delay:${i * 80}ms`}>
                    <p class="text-sm text-accent font-semibold">{t.date}</p>
                    <p class="text-sm text-primary/80 mt-1 leading-snug">{t.label}</p>
                  </div>
                )}
              </div>

              <div class="flex items-center justify-center py-1 z-[1]" style={`grid-column:${i + 1};grid-row:2`}>
                <div class="rounded-full bg-bg p-1">
                  <div class="w-10 h-10 rounded-full bg-accent text-white flex items-center justify-center text-sm font-bold shadow-lg shadow-accent/30 ring-[3px] ring-bg">{i + 1}</div>
                </div>
              </div>

              <div class="flex items-start justify-center pt-2 z-[1]" style={`grid-column:${i + 1};grid-row:3`}>
                {i % 2 === 0 && (
                  <div class="glass rounded-xl px-3 py-3 text-center border-t-2 border-accent w-[85%] break-words fade-in-up card-shadow" style={`transition-delay:${i * 80}ms`}>
                    <p class="text-sm text-accent font-semibold">{t.date}</p>
                    <p class="text-sm text-primary/80 mt-1 leading-snug">{t.label}</p>
                  </div>
                )}
              </div>
            </>
          ))}
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 overflow-hidden leading-[0] pointer-events-none" style="transform:translateY(1px)">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full h-10 md:h-14">
        <path d="M0,28 C240,56 480,0 720,28 C960,56 1200,0 1440,28 L1440,60 L0,60 Z" fill="#0D4720"/>
      </svg>
    </div>
  </section>

<!-- FEES -->
  {lomba.fees && (
    <section class="py-20 bg-bg relative overflow-hidden">
      <div class="max-w-6xl mx-auto px-4">
        <p class="text-xs text-text/40 uppercase tracking-[0.2em] font-bold mb-8 fade-in-up">Biaya Pendaftaran</p>
        <div class="grid sm:grid-cols-3 gap-4 fade-in-up" style="transition-delay:100ms">
          {lomba.fees.map((f, i) => (
            <div class="glass rounded-2xl p-6 text-center card-shadow hover:border-accent/30 transition-all duration-300">
              <p class="text-xs text-text/50 uppercase tracking-wider font-bold">{f.batch}</p>
              <p class="text-2xl md:text-3xl font-bold text-accent mt-2">{f.amount}</p>
              <p class="text-sm text-primary/60 mt-2">{f.period}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="absolute bottom-0 left-0 right-0 overflow-hidden leading-[0] pointer-events-none" style="transform:translateY(1px)">
        <svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full h-10 md:h-14">
          <path d="M0,28 C240,56 480,0 720,28 C960,56 1200,0 1440,28 L1440,60 L0,60 Z" fill="#114F25"/>
        </svg>
      </div>
    </section>
  )}

  <!-- CONTACTS -->
  <section class={`py-20 ${lomba.fees ? 'bg-surface' : 'bg-bg'} relative overflow-hidden`}>
    <div class="max-w-6xl mx-auto px-4">
      <p class="text-xs text-text/40 uppercase tracking-[0.2em] font-bold mb-8 fade-in-up">Narahubung</p>
      <div class="grid sm:grid-cols-2 gap-4 fade-in-up" style="transition-delay:100ms">
        {lomba.contacts.map((c) => (
          <a
            href={`https://wa.me/${c.phone.replace(/[^0-9]/g, "")}`}
            target="_blank" rel="noopener"
            class="glass rounded-2xl p-5 flex items-center gap-4 card-shadow hover:border-accent/30 transition-all duration-300 group"
          >
            <div class="w-12 h-12 rounded-xl bg-accent/15 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-primary font-semibold">{c.name}</p>
              <p class="text-sm text-text/60 group-hover:text-accent transition-colors">{c.phone}</p>
            </div>
            <svg class="w-5 h-5 text-text/30 group-hover:text-accent transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- LIGHTBOX -->
  <div id="poster-modal" class="fixed inset-0 z-[100] bg-black/90 opacity-0 pointer-events-none transition-opacity duration-300 overflow-hidden" style="backdrop-filter:blur(6px)">
    <button id="modal-close" class="absolute top-6 right-6 z-20 w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 backdrop-blur-sm flex items-center justify-center text-white transition-all cursor-pointer" aria-label="Tutup">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <div id="zoom-wrapper" class="w-full h-full flex items-center justify-center overflow-hidden">
      <img
        id="zoom-img"
        src={imgSrc}
        alt={`Poster ${lomba.name}`}
        class="rounded-lg shadow-2xl select-none"
        draggable="false"
        style="max-width:85vw;max-height:85vh;object-fit:contain;transform:scale(1) translate(0,0);cursor:grab"
      />
    </div>
    <div id="zoom-badge" class="absolute bottom-8 left-1/2 -translate-x-1/2 bg-white/15 backdrop-blur-md text-white/90 text-xs font-semibold px-4 py-2 rounded-full opacity-0 transition-opacity duration-300 pointer-events-none select-none border border-white/10">
      100%
    </div>
  </div>

  <Footer />
</BaseLayout>

<script>
  const thumb = document.getElementById("poster-img");
  const trigger = document.getElementById("poster-trigger");
  const modal = document.getElementById("poster-modal");
  const closeBtn = document.getElementById("modal-close");
  const zoomImg = document.getElementById("zoom-img");
  const wrapper = document.getElementById("zoom-wrapper");
  const badge = document.getElementById("zoom-badge");

  let scale = 1;
  let translateX = 0;
  let translateY = 0;
  let isDragging = false;
  let dragStartX = 0;
  let dragStartY = 0;
  let startTranslateX = 0;
  let startTranslateY = 0;
  let isPinching = false;
  let pinchStartDist = 0;
  let pinchStartScale = 1;
  let badgeTimer = null;

  const MIN_Z = 0.25;
  const MAX_Z = 10;

  function apply(smooth) {
    if (!zoomImg) return;
    zoomImg.style.transition = smooth ? "transform 0.2s" : "none";
    zoomImg.style.transform = `scale(${scale}) translate(${translateX}px, ${translateY}px)`;
  }

  function badgeShow() {
    if (!badge) return;
    badge.textContent = Math.round(scale * 100) + "%";
    badge.classList.remove("opacity-0");
    badge.classList.add("opacity-100");
    clearTimeout(badgeTimer);
    badgeTimer = setTimeout(() => {
      badge.classList.remove("opacity-100");
      badge.classList.add("opacity-0");
    }, 1200);
  }

  function openModal() {
    if (!modal) return;
    scale = 1;
    translateX = 0;
    translateY = 0;
    apply(false);
    modal.classList.remove("opacity-0", "pointer-events-none");
    modal.classList.add("opacity-100", "pointer-events-auto");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    if (!modal) return;
    modal.classList.remove("opacity-100", "pointer-events-auto");
    modal.classList.add("opacity-0", "pointer-events-none");
    document.body.style.overflow = "";
    if (badge) {
      badge.classList.add("opacity-0");
      badge.classList.remove("opacity-100");
    }
  }

  trigger?.addEventListener("click", openModal);
  closeBtn?.addEventListener("click", closeModal);
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeModal(); });
  wrapper?.addEventListener("click", (e) => { if (e.target === wrapper) closeModal(); });

  wrapper?.addEventListener("wheel", (e) => {
    e.preventDefault();
    const delta = e.deltaY > 0 ? -0.1 : 0.1;
    scale = Math.min(MAX_Z, Math.max(MIN_Z, scale + delta));
    apply(true);
    badgeShow();
  }, { passive: false });

  zoomImg?.addEventListener("mousedown", (e) => {
    isDragging = true;
    dragStartX = e.clientX;
    dragStartY = e.clientY;
    startTranslateX = translateX;
    startTranslateY = translateY;
    zoomImg.style.cursor = "grabbing";
    zoomImg.style.transition = "none";
  });

  document.addEventListener("mousemove", (e) => {
    if (!isDragging) return;
    const dx = e.clientX - dragStartX;
    const dy = e.clientY - dragStartY;
    translateX = startTranslateX + dx / scale;
    translateY = startTranslateY + dy / scale;
    if (zoomImg) zoomImg.style.transform = `scale(${scale}) translate(${translateX}px, ${translateY}px)`;
  });

  document.addEventListener("mouseup", () => {
    if (isDragging) {
      isDragging = false;
      if (zoomImg) zoomImg.style.cursor = "grab";
    }
  });

  zoomImg?.addEventListener("dblclick", (e) => {
    if (scale > 1.3) {
      scale = 1; translateX = 0; translateY = 0;
      apply(true); badgeShow();
    } else {
      scale = 3;
      const rect = zoomImg.getBoundingClientRect();
      const cx = (e.clientX - rect.left) / rect.width;
      const cy = (e.clientY - rect.top) / rect.height;
      translateX = -(cx - 0.5) * rect.width * (scale - 1) / scale;
      translateY = -(cy - 0.5) * rect.height * (scale - 1) / scale;
      apply(true); badgeShow();
    }
  });

  wrapper?.addEventListener("touchstart", (e) => {
    if (e.touches.length === 2) {
      isPinching = true;
      const t1 = e.touches[0];
      const t2 = e.touches[1];
      pinchStartDist = Math.hypot(t2.clientX - t1.clientX, t2.clientY - t1.clientY);
      pinchStartScale = scale;
    }
  }, { passive: true });

  wrapper?.addEventListener("touchmove", (e) => {
    if (isPinching && e.touches.length === 2) {
      e.preventDefault();
      const t1 = e.touches[0];
      const t2 = e.touches[1];
      const dist = Math.hypot(t2.clientX - t1.clientX, t2.clientY - t1.clientY);
      const ratio = dist / pinchStartDist;
      scale = Math.min(MAX_Z, Math.max(MIN_Z, pinchStartScale * ratio));
      apply(true); badgeShow();
    }
  }, { passive: false });

  wrapper?.addEventListener("touchend", () => { isPinching = false; }, { passive: true });
</script>